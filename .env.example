APP_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/afya_erp
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_MINUTES=180
LOG_LEVEL=INFO
